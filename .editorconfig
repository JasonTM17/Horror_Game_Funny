# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = tab
indent_size = 4

[*.{md,yml,yaml,json}]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

[*.{ps1,psm1}]
end_of_line = crlf
indent_style = space
indent_size = 4

[*.{gd,gdshader,tscn,tres,godot}]
indent_style = tab
indent_size = 4

[Dockerfile]
indent_style = tab
indent_size = 4

[*.sh]
end_of_line = lf
indent_style = tab
indent_size = 4
